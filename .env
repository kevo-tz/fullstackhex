# Database Configuration (PostgreSQL)
# TODO: Replace dev-password values with strong credentials before first use
POSTGRES_USER=app_user
POSTGRES_PASSWORD=dev-password
POSTGRES_DB=app_database
POSTGRES_PORT=5432
DATABASE_URL=postgres://app_user:dev-password@localhost:5432/app_database
DB_MAX_CONNECTIONS=5

# Redis Configuration
REDIS_PORT=6379
# TODO: Replace dev-password with a strong password before use
# Production: REDIS_URL must include password: redis://:${REDIS_PASSWORD}@localhost:${REDIS_PORT}
REDIS_PASSWORD=dev-password
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:${REDIS_PORT}
REDIS_MAX_MEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_APPENDONLY=yes
REDIS_SAVE="900 1 300 10 60 10000"
REDIS_KEY_PREFIX=fullstackhex
REDIS_POOL_SIZE=10

# RustFS (S3-compatible Object Storage)
# TODO: Replace dev-password values with strong credentials before first use
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
RUSTFS_ENDPOINT=http://localhost:${RUSTFS_API_PORT}
RUSTFS_ACCESS_KEY=dev-password
RUSTFS_SECRET_KEY=dev-password
RUSTFS_CORS_ORIGINS=*

# Python Sidecar (Unix socket)
# Dev: /tmp/fullstackhex-python.sock
# Prod (compose/prod.yml): /tmp/sidecar/python-sidecar.sock
# Override with: PYTHON_SIDECAR_SOCKET=/custom/path/to/socket.sock
PYTHON_SIDECAR_SOCKET=/tmp/fullstackhex-python.sock

# Logging
RUST_LOG=info
PYTHON_LOG_LEVEL=info

# Node.js / Frontend
NODE_ENV=development
ASTRO_PORT=4321
PUBLIC_API_URL=http://localhost:8001
VITE_RUST_BACKEND_URL=http://localhost:8001

# Monitoring (Optional - requires separate compose profiles)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ALERTMANAGER_PORT=9093
NODE_EXPORTER_PORT=9100
REDIS_EXPORTER_PORT=9121
POSTGRES_EXPORTER_PORT=9187
GRAFANA_ADMIN_USER=admin
# TODO: Replace dev-password with a strong password before enabling Grafana
GRAFANA_ADMIN_PASSWORD=dev-password

# Nginx (Production)
NGINX_PORT=80
HTTPS_PORT=443

# Deployment (Optional — only needed for make deploy)
# DEPLOY_HOST=your-vps.example.com
# DEPLOY_USER=ubuntu
# DEPLOY_PATH=/opt/fullstackhex
# DEPLOY_SSH_KEY=~/.ssh/id_ed25519  # optional fallback if ssh-agent not used

# Authentication (v0.8)
AUTH_MODE=both
JWT_SECRET=dev-jwt-secret-not-for-production
JWT_ISSUER=fullstackhex
JWT_EXPIRY=900
JWT_REFRESH_EXPIRY=604800
SIDECAR_SHARED_SECRET=dev-shared-secret-not-for-production

# Storage — S3 / RustFS (v0.8)
RUSTFS_BUCKET=fullstackhex
RUSTFS_REGION=us-east-1
RUSTFS_AUTO_CREATE_BUCKET=true

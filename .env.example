# Database Configuration (PostgreSQL)
# TODO: Replace CHANGE_ME values with strong credentials before first use
POSTGRES_USER=app_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=app_database
POSTGRES_PORT=5432
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://localhost:${REDIS_PORT}
REDIS_MAX_MEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_APPENDONLY=yes
REDIS_SAVE=900 1 300 10 60 10000

# RustFS (S3-compatible Object Storage)
# TODO: Replace CHANGE_ME values with strong credentials before first use
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
RUSTFS_ENDPOINT=http://localhost:${RUSTFS_API_PORT}
RUSTFS_ACCESS_KEY=CHANGE_ME
RUSTFS_SECRET_KEY=CHANGE_ME
RUSTFS_CORS_ORIGINS=*

# Logging
RUST_LOG=info
PYTHON_LOG_LEVEL=info

# Node.js / Frontend
NODE_ENV=development
ASTRO_PORT=4321
PUBLIC_API_URL=http://localhost:8001
VITE_RUST_BACKEND_URL=http://localhost:8001

# Monitoring (Optional - requires separate compose profiles)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
# TODO: Replace CHANGE_ME with a strong password before enabling Grafana
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# Nginx (Production)
NGINX_PORT=80
HTTPS_PORT=443

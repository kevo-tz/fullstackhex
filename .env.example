# Rust Backend Service
RUST_SERVICE_DB_URL=postgres://user:password@localhost:5432/rust_service

# Python Services
PYTHON_SERVICE_DB_URL=postgres://user:password@localhost:5433/python_service

# RustFS (MinIO) Configuration
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=minioadmin
RUSTFS_SECRET_KEY=minioadmin

# Logging
RUST_LOG=info

# Node.js
NODE_ENV=development

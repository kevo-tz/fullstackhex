# Database Configuration (PostgreSQL)
# TODO: Replace CHANGE_ME values with strong credentials before first use
POSTGRES_USER=app_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=app_database
POSTGRES_PORT=5432
# TODO: Replace CHANGE_ME values with strong credentials before first use
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
DB_MAX_CONNECTIONS=20

# Redis Configuration
REDIS_PORT=6379
# TODO: Replace CHANGE_ME with a strong password before use
# Production: REDIS_URL must include password: redis://:${REDIS_PASSWORD}@localhost:${REDIS_PORT}
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:${REDIS_PORT}
REDIS_MAX_MEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_APPENDONLY=yes
REDIS_SAVE="900 1 300 10 60 10000"
REDIS_KEY_PREFIX=fullstackhex
REDIS_POOL_SIZE=10

# RustFS (S3-compatible Object Storage)
# TODO: Replace CHANGE_ME values with strong credentials before first use
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
RUSTFS_ENDPOINT=http://localhost:${RUSTFS_API_PORT}
RUSTFS_ACCESS_KEY=CHANGE_ME
RUSTFS_SECRET_KEY=CHANGE_ME
RUSTFS_CORS_ORIGINS=*  # Restrict to frontend origin in production, e.g. https://app.example.com
RUSTFS_BUCKET=fullstackhex
RUSTFS_REGION=us-east-1
RUSTFS_AUTO_CREATE_BUCKET=true

# Python API (Unix socket)
# Dev: /tmp/fullstackhex-python.sock
# Prod (compose/prod.yml): /tmp/sidecar/py-api.sock
# Override with: PYTHON_SIDECAR_SOCKET=/custom/path/to/socket.sock
PYTHON_SIDECAR_SOCKET=/tmp/fullstackhex-python.sock
# Alias for PYTHON_SIDECAR_SOCKET (preferred name; PYTHON_SIDECAR_SOCKET is deprecated)
# PY_API_SOCKET=/tmp/fullstackhex-python.sock

# Logging
RUST_LOG=info
PYTHON_LOG_LEVEL=info

# Node.js / Frontend
NODE_ENV=development
ASTRO_PORT=4321
PUBLIC_API_URL=http://localhost:8001

# WebSocket — tune connection pool and idle timeout
# WS_MAX_CONNECTIONS=100
# WS_IDLE_TIMEOUT_SECS=300
VITE_RUST_BACKEND_URL=http://localhost:8001

# Monitoring (Optional - requires separate compose profiles)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
# TODO: Replace CHANGE_ME with a strong password before enabling Grafana
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
ALERTMANAGER_PORT=9093
NODE_EXPORTER_PORT=9100
REDIS_EXPORTER_PORT=9121
POSTGRES_EXPORTER_PORT=9187

# Nginx (Production)
NGINX_PORT=80
HTTPS_PORT=443

# Deployment (Optional — only needed for make deploy)
# DEPLOY_HOST=your-vps.example.com
# DEPLOY_USER=ubuntu
# DEPLOY_PATH=/opt/fullstackhex
# DEPLOY_SSH_KEY=~/.ssh/id_ed25519  # optional fallback if ssh-agent not used

# ─────────────────────────────────────
# Authentication (v0.8)
# ─────────────────────────────────────
# AUTH_MODE controls authentication behavior.
# - cookie: session cookie only (requires CSRF token for state-changing requests)
# - bearer: Authorization: Bearer <token> header only
# - both:   bearer takes precedence if present; cookie is fallback (default)
AUTH_MODE=both
# TODO: Replace CHANGE_ME with a strong secret (generate: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME
JWT_ISSUER=fullstackhex
# Access token expiry in seconds (default: 15 minutes)
JWT_EXPIRY=900
# Refresh token expiry in seconds (default: 7 days)
JWT_REFRESH_EXPIRY=604800

# OAuth — Google
# GOOGLE_CLIENT_ID=CHANGE_ME
# GOOGLE_CLIENT_SECRET=CHANGE_ME

# OAuth — GitHub
# GITHUB_CLIENT_ID=CHANGE_ME
# GITHUB_CLIENT_SECRET=CHANGE_ME

# OAuth callback URL (default: http://localhost:8001)
# OAUTH_REDIRECT_URL=http://localhost:8001/auth/oauth

# When true (default), allow requests through Redis blacklist check failures.
# Set to false to reject requests when Redis blacklist check is unavailable.
# AUTH_FAIL_OPEN_ON_REDIS_ERROR=true

# Python sidecar HMAC shared secret — guards auth header forwarding
# If not set, ALL requests to Python sidecar are rejected (fail-closed).
# TODO: Replace CHANGE_ME with a strong secret (generate: openssl rand -hex 32)
SIDECAR_SHARED_SECRET=CHANGE_ME

# WebSocket Configuration
WS_MAX_CONNECTIONS=100
WS_IDLE_TIMEOUT_SECS=300

# Feature Flags — control optional features at startup. All default to false.
# FEATURE_CHAT=true
# FEATURE_STORAGE_READONLY=true
# FEATURE_MAINTENANCE=true
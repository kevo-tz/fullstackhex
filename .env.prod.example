# Production Environment Template for FullStackHex
# Copy to .env in production and replace all CHANGE_ME values.

# Runtime
VERSION=latest
RUST_LOG=info
PYTHON_LOG_LEVEL=info

# PostgreSQL
POSTGRES_USER=app_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=app_database
POSTGRES_PORT=5432
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:${REDIS_PORT}
REDIS_MAX_MEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_APPENDONLY=yes
REDIS_SAVE=900 1 300 10 60 10000

# RustFS
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
RUSTFS_ENDPOINT=http://rustfs:${RUSTFS_API_PORT}
RUSTFS_ACCESS_KEY=CHANGE_ME
RUSTFS_SECRET_KEY=CHANGE_ME
RUSTFS_CORS_ORIGINS=https://your-frontend-domain.example

# Frontend and API
PUBLIC_API_URL=https://api.your-domain.example
VITE_RUST_BACKEND_URL=http://rust-backend:8001

# Nginx
NGINX_PORT=80
HTTPS_PORT=443

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GRAFANA_DOMAIN=grafana.your-domain.example

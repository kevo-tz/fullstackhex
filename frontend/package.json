{
  "name": "frontend",
  "type": "module",
  "version": "0.10.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "astro check",
    "test:vitest": "vitest run"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.6",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.2.1",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "knip": "^6.11.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "bun-types": "^1.3.13",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "knip": {
    "$schema": "https://unpkg.com/knip@6/schema.json",
    "entry": [
      "src/**/*.ts",
      "src/**/*.astro",
      "src/lib/health.ts",
      "tests/**/*.ts"
    ],
    "project": [
      "src/**/*.ts",
      "src/**/*.astro",
      "tests/**/*.ts"
    ],
    "ignoreDependencies": [
      "tailwindcss"
    ]
  }
}

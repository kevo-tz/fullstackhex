---
export interface Props {
  label: string;
  value: string;
  trend?: string;
}

const { label, value, trend } = Astro.props;
---
<div class="card">
  <span class="card-label">{label}</span>
  <span class="card-value">{value}</span>
  {trend && <span class="card-trend">{trend}</span>}
</div>

<style>
  .card {
    border: 1px solid #1e293b;
    border-radius: 8px;
    padding: 1.25rem;
    background: #111827;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .card-label {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #475569;
  }
  .card-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #e2e8f0;
  }
  .card-trend {
    font-size: 0.75rem;
    color: var(--accent, #22c55e);
  }
</style>

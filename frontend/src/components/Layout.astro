---
export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/layout.css" />
  </head>
  <body>
    <nav>
      <a href="/" class="brand">FullStackHex</a>
      <div class="nav-links">
        <a href="/">Dashboard</a>
        <div id="auth-nav"></div>
        <button class="theme-btn" id="theme-toggle" aria-label="Toggle theme">
          <svg class="sun-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg class="moon-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
        </button>
      </div>
      <button class="hamburger-btn" aria-expanded="false" aria-controls="nav-menu" aria-label="Toggle navigation" id="hamburger-btn">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M3 6h18M3 12h18M3 18h18"/>
        </svg>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="display:none">
          <path d="M6 6l12 12M6 18L18 6"/>
        </svg>
      </button>
    </nav>
    <div id="nav-menu" role="navigation" aria-label="Main menu" aria-hidden="true">
      <a href="/">Dashboard</a>
      <div id="auth-nav-mobile"></div>
      <button class="theme-btn" id="theme-toggle-mobile" aria-label="Toggle theme">
        <svg class="sun-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <svg class="moon-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </button>
    </div>
    <div class="container">
      <slot />
    </div>
    <footer>port 8001 &middot; <a href="https://github.com/kevo-tz/fullstackhex" style="color:inherit">github.com/kevo-tz/fullstackhex</a></footer>
    <script>
      async function fetchUser(): Promise<Record<string, string> | null> {
        try {
          const res = await fetch("/api/auth/me");
          if (!res.ok) return null;
          return await res.json();
        } catch {
          return null;
        }
      }

      async function updateNav() {
        const el = document.getElementById("auth-nav");
        const elMobile = document.getElementById("auth-nav-mobile");
        const user = await fetchUser();

        function buildUserNav(u: Record<string, string>) {
          const span = document.createElement("span");
          span.className = "user-menu";
          span.textContent = u.email;

          const logoutBtn = document.createElement("button");
          logoutBtn.className = "logout-btn";
          logoutBtn.id = "nav-logout";
          logoutBtn.textContent = "logout";

          const logoutBtnMobile = document.createElement("button");
          logoutBtnMobile.className = "logout-btn";
          logoutBtnMobile.id = "nav-logout-mobile";
          logoutBtnMobile.textContent = "logout";

          return [span, logoutBtn, logoutBtnMobile];
        }

        function buildGuestNav() {
          const a = document.createElement("a");
          a.href = "/login";
          a.textContent = "login";
          return [a];
        }

        function setNav(parent: HTMLElement, children: Element[]) {
          parent.textContent = "";
          for (const child of children) {
            parent.appendChild(child);
          }
        }

        if (user) {
          if (el) setNav(el, buildUserNav(user));
          if (elMobile) setNav(elMobile, buildUserNav(user));
        } else {
          if (el) setNav(el, buildGuestNav());
          if (elMobile) setNav(elMobile, buildGuestNav());
        }

        document.getElementById("nav-logout")?.addEventListener("click", logout);
        document.getElementById("nav-logout-mobile")?.addEventListener("click", logout);
      }

      async function logout() {
        try {
          await fetch("/api/auth/logout", { method: "POST" });
        } catch { /* server session cleanup is best-effort */ }
        document.cookie = "access_token=; path=/; max-age=0";
        document.cookie = "refresh_token=; path=/; max-age=0";
        window.location.href = "/login";
      }
      interface CustomWindow extends Window {
        logout?: () => void;
      }
      (window as CustomWindow).logout = logout;

      const origFetch = window.fetch.bind(window);
      let refreshPromise: Promise<boolean> | null = null;

      async function performRefresh(): Promise<boolean> {
        try {
          const refreshRes = await origFetch("/api/auth/refresh", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({}),
          });
          if (refreshRes.ok) {
            return true;
          }
          document.cookie = "access_token=; path=/; max-age=0";
          document.cookie = "refresh_token=; path=/; max-age=0";
          window.location.href = "/login";
          return false;
        } catch (err) {
          console.warn("Token refresh failed:", err instanceof Error ? err.message : String(err));
          return false;
        }
      }

      window.fetch = (async (input: RequestInfo | URL, init?: RequestInit): Promise<Response> => {
        const res = await origFetch(input, init);
        if (res.status === 401 && !(init?.method === "POST" && typeof init?.body === "string" && (init.headers as Record<string, string>)?.["Content-Type"]?.includes("multipart/form-data"))) {
          if (!refreshPromise) {
            refreshPromise = performRefresh().finally(() => { refreshPromise = null; });
          }
          const ok = await refreshPromise;
          if (ok) {
            try {
              const retryReq = new Request(input, init);
              return origFetch(retryReq);
            } catch {
              return res;
            }
          }
        }
        return res;
      }) as typeof fetch;

      updateNav();

      // Init theme from localStorage
      try { const t = localStorage.getItem("theme"); if (t) document.documentElement.dataset.theme = t; } catch { /* localStorage may be blocked in private browsing */ }

      // Theme toggle
      function toggleTheme() {
        var html = document.documentElement;
        var next = html.dataset.theme === "dark" ? "light" : "dark";
        html.dataset.theme = next;
        try { localStorage.setItem("theme", next); } catch { /* localStorage may be blocked in private browsing */ }
      }

      document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
      document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);

      // Hamburger
      var hamburger = document.getElementById("hamburger-btn");
      var navMenu = document.getElementById("nav-menu");

      hamburger?.addEventListener("click", function() {
        var self = hamburger!;
        var open = self.getAttribute("aria-expanded") === "true";
        self.setAttribute("aria-expanded", String(!open));
        if (navMenu) navMenu.setAttribute("aria-hidden", String(open));
      });

      document.addEventListener("keydown", function(e) {
        if (e.key === "Escape" && hamburger?.getAttribute("aria-expanded") === "true") {
          hamburger?.setAttribute("aria-expanded", "false");
          if (navMenu) navMenu.setAttribute("aria-hidden", "true");
        }
      });
    </script>
  </body>
</html>

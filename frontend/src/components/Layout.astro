---
export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, Consolas, monospace;
        background: #0d0d0d;
        color: #e2e8f0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem;
      }

      .container { max-width: 640px; width: 100%; }

      /* Nav */
      nav {
        width: 100%;
        max-width: 640px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 1rem;
        margin-bottom: 2rem;
        border-bottom: 1px solid #1e293b;
      }
      nav a {
        color: #64748b;
        text-decoration: none;
        font-size: 0.8rem;
        transition: color 0.15s;
      }
      nav a:hover { color: #94a3b8; }
      nav .brand {
        font-weight: 700;
        font-size: 1rem;
        color: #f8fafc;
        letter-spacing: -0.02em;
      }
      nav .nav-links { display: flex; gap: 1.25rem; align-items: center; }
      nav .user-menu {
        font-size: 0.75rem;
        color: #94a3b8;
      }
      nav .logout-btn {
        background: none;
        border: 1px solid #1e293b;
        border-radius: 4px;
        color: #64748b;
        font-family: inherit;
        font-size: 0.7rem;
        padding: 0.25rem 0.5rem;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
      }
      nav .logout-btn:hover { border-color: #ef4444; color: #ef4444; }

      /* Shared card style */
      .card {
        border: 1px solid #1e293b;
        border-radius: 8px;
        padding: 1.25rem;
        background: #111827;
      }

      /* Form styles */
      .form-group { margin-bottom: 1rem; }
      .form-group label {
        display: block;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #475569;
        margin-bottom: 0.5rem;
      }
      .form-group input {
        width: 100%;
        padding: 0.6rem 0.75rem;
        background: #0a0a0a;
        border: 1px solid #1e293b;
        border-radius: 6px;
        color: #e2e8f0;
        font-family: inherit;
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.15s;
      }
      .form-group input:focus { border-color: #334155; }
      .form-group input::placeholder { color: #334155; }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        width: 100%;
        padding: 0.6rem 1rem;
        border: 1px solid #1e293b;
        border-radius: 6px;
        background: #f8fafc;
        color: #0d0d0d;
        font-family: inherit;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s;
      }
      .btn:hover { background: #e2e8f0; }
      .btn:disabled { opacity: 0.5; cursor: not-allowed; }

      .btn-oauth {
        background: transparent;
        color: #94a3b8;
        margin-top: 0.5rem;
      }
      .btn-oauth:hover { border-color: #334155; background: transparent; color: #e2e8f0; }

      .divider {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin: 1.25rem 0;
        color: #1e293b;
        font-size: 0.7rem;
      }
      .divider::before, .divider::after {
        content: "";
        flex: 1;
        border-top: 1px solid #1e293b;
      }

      .error-msg {
        padding: 0.6rem 0.75rem;
        background: #1a0a0a;
        border: 1px solid #3b1111;
        border-radius: 6px;
        color: #ef4444;
        font-size: 0.8rem;
        margin-bottom: 1rem;
        display: none;
      }
      .error-msg.visible { display: block; }

      .form-footer {
        text-align: center;
        margin-top: 1.25rem;
        font-size: 0.8rem;
        color: #475569;
      }
      .form-footer a { color: #94a3b8; text-decoration: none; }
      .form-footer a:hover { color: #e2e8f0; }

      footer {
        margin-top: 2.5rem;
        text-align: center;
        font-size: 0.75rem;
        color: #1e293b;
      }
    </style>
    <script>
      // Auth state hydrator - runs before page paint
      const TOKEN_KEY = "fullstackhex_token";
      const USER_KEY = "fullstackhex_user";
    </script>
  </head>
  <body>
    <nav>
      <a href="/" class="brand">FullStackHex</a>
      <div class="nav-links">
        <a href="/">Dashboard</a>
        <div id="auth-nav"></div>
      </div>
    </nav>
    <div class="container">
      <slot />
    </div>
    <footer>port 8001 &middot; <a href="https://github.com/kevo-tz/fullstackhex" style="color:inherit">github.com/kevo-tz/fullstackhex</a></footer>
    <script>
      function updateNav() {
        const el = document.getElementById("auth-nav");
        if (!el) return;
        const user = localStorage.getItem(USER_KEY);
        if (user) {
          try {
            const u = JSON.parse(user);
            el.innerHTML = `<span class="user-menu">${u.email}</span>
              <button class="logout-btn" id="nav-logout">logout</button>`;
            document.getElementById("nav-logout")?.addEventListener("click", async () => {
              try { await fetch("/api/auth/logout", { method: "POST" }); } catch {}
              localStorage.removeItem(TOKEN_KEY);
              localStorage.removeItem(USER_KEY);
              window.location.href = "/";
            });
          } catch {
            el.innerHTML = `<a href="/login">login</a>`;
          }
        } else {
          el.innerHTML = `<a href="/login">login</a>`;
        }
      }
      updateNav();
    </script>
  </body>
</html>

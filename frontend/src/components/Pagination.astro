---
export interface Props {
  currentPage?: number;
  totalPages?: number;
}

const { currentPage = 1, totalPages = 1 } = Astro.props;
const prevDisabled = currentPage <= 1;
const nextDisabled = currentPage >= totalPages;
---

<nav class="pagination" aria-label="Pagination">
  <button class="page-btn" disabled={prevDisabled} data-page={currentPage - 1} aria-label="Previous page">← Previous</button>
  <span class="page-info">{currentPage} / {totalPages}</span>
  <button class="page-btn" disabled={nextDisabled} data-page={currentPage + 1} aria-label="Next page">Next →</button>
</nav>

<style>
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1rem 0;
  }
  .page-btn {
    padding: 0.4rem 0.9rem;
    border: 1px solid #1e293b;
    border-radius: 6px;
    background: transparent;
    color: #94a3b8;
    font-size: 0.8rem;
    cursor: pointer;
    font-family: inherit;
  }
  .page-btn:hover:not(:disabled) { border-color: #334155; color: #e2e8f0; }
  .page-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .page-info { font-size: 0.8rem; color: #475569; }
</style>

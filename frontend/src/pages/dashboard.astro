---
import Layout from "../components/Layout.astro";
---

<Layout title="Dashboard — FullStackHex">

  <div id="dashboard-content" style="display:none">
    <div class="dash-header">
      <h1>Dashboard</h1>
      <p>Welcome back</p>
    </div>

    <div class="card">
      <div class="card-label">Account</div>
      <div class="user-info" id="user-info">
        <div class="row"><span class="label">Email</span><span id="user-email"></span></div>
        <div class="row"><span class="label">Name</span><span id="user-name"></span></div>
        <div class="row"><span class="label">Provider</span><span id="user-provider"></span></div>
      </div>
      <button class="btn btn-ghost" id="dashboard-logout" style="margin-top:1rem">Log out</button>
    </div>
  </div>

  <div class="guard-msg" id="auth-guard" style="display:none">
    <p>You need to be logged in to view this page.</p>
    <a href="/login" class="btn" style="display:inline-block;width:auto;">Sign in</a>
  </div>

  <script>
    async function initDashboard() {
      try {
        const res = await fetch("/api/auth/me");
        if (!res.ok) {
          const guard = document.getElementById("auth-guard");
          if (guard) guard.style.display = "block";
          return;
        }
        const user = await res.json();
        const content = document.getElementById("dashboard-content");
        if (content) content.style.display = "block";
        const userEmail = document.getElementById("user-email");
        if (userEmail) userEmail.textContent = user.email || "\u2014";
        const userName = document.getElementById("user-name");
        if (userName) userName.textContent = user.name || "\u2014";
        const userProvider = document.getElementById("user-provider");
        if (userProvider) userProvider.textContent = user.provider || "email";
      } catch {
        const guard = document.getElementById("auth-guard");
        if (guard) guard.style.display = "block";
      }
    }

    document.getElementById("dashboard-logout")?.addEventListener("click", () => {
      interface CustomWindow extends Window { logout?: () => void; }
      const win = window as CustomWindow;
      if (typeof win.logout === "function") win.logout();
    });

    initDashboard();
  </script>
</Layout>

---
import Layout from "../components/Layout.astro";
---

<Layout title="Dashboard — FullStackHex">
  <style>
    .dash-header { margin-bottom: 2.5rem; text-align: center; }
    .dash-header h1 { font-size: 2rem; font-weight: 700; letter-spacing: -0.02em; color: var(--text); }
    .dash-header p { margin-top: 0.5rem; color: var(--text-muted); font-size: 0.875rem; }

    .card {
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.25rem;
      background: var(--card-bg);
      margin-bottom: 1rem;
    }

    .card-label {
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
    }

    .user-info {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .user-info .row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.85rem;
      color: var(--text);
    }

    .user-info .label {
      color: var(--text-muted);
      font-size: 0.75rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      width: 100%;
      padding: 0.6rem 1rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--btn-bg);
      color: var(--btn-text);
      font-family: inherit;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 1rem;
    }
    .btn:hover { background: #e2e8f0; }
    [data-theme="light"] .btn:hover { background: #1e293b; }

    .btn-ghost {
      background: transparent;
      color: var(--text-muted);
      border-color: var(--border);
    }

    .guard-msg {
      text-align: center;
      padding: 3rem 1rem;
    }
    .guard-msg p { color: var(--text-muted); margin-bottom: 1rem; }
  </style>

  <div id="dashboard-content" style="display:none">
    <div class="dash-header">
      <h1>Dashboard</h1>
      <p>Welcome back</p>
    </div>

    <div class="card">
      <div class="card-label">Account</div>
      <div class="user-info" id="user-info">
        <div class="row"><span class="label">Email</span><span id="user-email"></span></div>
        <div class="row"><span class="label">Name</span><span id="user-name"></span></div>
        <div class="row"><span class="label">Provider</span><span id="user-provider"></span></div>
      </div>
      <button class="btn btn-ghost" id="dashboard-logout">Log out</button>
    </div>
  </div>

  <div class="guard-msg" id="auth-guard" style="display:none">
    <p>You need to be logged in to view this page.</p>
    <a href="/login" class="btn" style="display:inline-block;width:auto;">Sign in</a>
  </div>

  <script>
    async function initDashboard() {
      try {
        const res = await fetch("/api/auth/me");
        if (!res.ok) {
          const guard = document.getElementById("auth-guard");
          if (guard) guard.style.display = "block";
          return;
        }
        const user = await res.json();
        const content = document.getElementById("dashboard-content");
        if (content) content.style.display = "block";
        const userEmail = document.getElementById("user-email");
        if (userEmail) userEmail.textContent = user.email || "\u2014";
        const userName = document.getElementById("user-name");
        if (userName) userName.textContent = user.name || "\u2014";
        const userProvider = document.getElementById("user-provider");
        if (userProvider) userProvider.textContent = user.provider || "email";
      } catch {
        const guard = document.getElementById("auth-guard");
        if (guard) guard.style.display = "block";
      }
    }

    document.getElementById("dashboard-logout")?.addEventListener("click", () => {
      interface CustomWindow extends Window { logout?: () => void; }
      const win = window as CustomWindow;
      if (typeof win.logout === "function") win.logout();
    });

    initDashboard();
  </script>
</Layout>

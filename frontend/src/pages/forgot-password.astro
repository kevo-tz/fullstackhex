---
import Layout from "../components/Layout.astro";
---

<Layout title="Forgot password — FullStackHex">
  <div class="max-w-sm mx-auto" style="margin-top:3rem">
    <header style="margin-bottom:2rem;text-align:center">
      <h1 style="font-size:1.5rem;font-weight:700;color:#f8fafc">Forgot password</h1>
    </header>

    <div class="card" style="max-width:400px;margin:0 auto">
      <div class="error-msg" id="auth-error"></div>
      <div class="success-msg hidden" id="auth-success"></div>

      <form id="forgot-form">
        <div class="form-group">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" placeholder="you@example.com" required autocomplete="email" />
        </div>
        <button type="submit" class="btn" id="submit-btn">Send reset link</button>
      </form>

    </div>

    <div class="form-footer">
      <a href="/login">Back to sign in</a>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById("forgot-form") as HTMLFormElement;
  const error = document.getElementById("auth-error") as HTMLDivElement;
  const success = document.getElementById("auth-success") as HTMLDivElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;

  function showError(msg: string) {
    error.textContent = msg;
    error.classList.add("visible");
  }
  function hideError() {
    error.textContent = "";
    error.classList.remove("visible");
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    hideError();
    success.classList.add("hidden");
    btn.disabled = true;
    btn.textContent = "…";

    const email = (document.getElementById("email") as HTMLInputElement).value;

    try {
      const res = await fetch("/api/auth/forgot-password", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        const msg = typeof data.error === "string" ? data.error : `Request failed (${res.status})`;
        throw new Error(msg);
      }

      const data = await res.json();
      success.textContent = data.message || "If that email is registered, a reset link has been generated.";
      success.classList.remove("hidden");
    } catch (err) {
      showError(err instanceof Error ? err.message : "Something went wrong");
    } finally {
      btn.disabled = false;
      btn.textContent = "Send reset link";
    }
  });
</script>

<style>
  .card {
    padding: 2rem;
    border-radius: 12px;
    background: var(--card-bg, #111827);
    border: 1px solid var(--border, #1e293b);
  }
  .form-group { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1rem; }
  .form-group label { font-size: 0.8rem; color: var(--text-muted, #94a3b8); }
  .form-group input {
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--border, #1e293b);
    border-radius: 6px;
    background: var(--card-bg, #111827);
    color: var(--text, #e2e8f0);
    font-size: 0.9rem;
    font-family: inherit;
    width: 100%;
    box-sizing: border-box;
  }
  .form-group input:focus { outline: none; border-color: var(--accent, #22c55e); }
  .btn {
    width: 100%;
    padding: 0.65rem;
    border-radius: 6px;
    background: var(--accent, #22c55e);
    color: var(--btn-text, #0d0d0d);
    border: none;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
  }
  .btn:hover { opacity: 0.9; }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .error-msg {
    padding: 0.65rem;
    border-radius: 6px;
    background: #450a0a;
    border: 1px solid #7f1d1d;
    color: #fca5a5;
    font-size: 0.82rem;
    margin-bottom: 1rem;
    display: none;
  }
  .error-msg.visible { display: block; }
  .success-msg {
    padding: 0.65rem;
    border-radius: 6px;
    background: #064e3b;
    border: 1px solid #065f46;
    color: #6ee7b7;
    font-size: 0.82rem;
    margin-bottom: 1rem;
  }
  .form-footer { text-align: center; margin-top: 1.5rem; }
  .form-footer a { color: var(--accent, #22c55e); font-size: 0.85rem; text-decoration: none; }
  .form-footer a:hover { text-decoration: underline; }
  .hidden { display: none; }
</style>

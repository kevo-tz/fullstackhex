---
import Layout from "../components/Layout.astro";
---

<Layout title="FullStackHex">
  <style>
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .card {
      border: 1px solid #1e293b;
      border-radius: 8px;
      padding: 1.25rem;
      background: #111827;
      transition: border-color 0.2s;
    }

    .card-label {
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #475569;
      margin-bottom: 0.75rem;
    }

    .status-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
      background: #334155;
    }
    .dot.ok       { background: var(--accent); box-shadow: 0 0 6px var(--accent-dot-shadow); }
    .dot.degraded { background: var(--dot-amber); box-shadow: 0 0 6px #f59e0b88; }
    .dot.error    { background: #ef4444; box-shadow: 0 0 6px #ef444488; }
    .dot.loading  { background: #334155; animation: pulse 1.2s ease-in-out infinite; }

    @keyframes pulse { 0%,100% { opacity: 1 } 50% { opacity: 0.3 } }

    .status-text { font-size: 0.9rem; color: #94a3b8; }

    .detail {
      margin-top: 0.75rem;
      font-size: 0.7rem;
      color: var(--text-muted);
      white-space: pre-wrap;
      word-break: break-word;
      max-height: 80px;
      overflow: auto;
    }

    .diagnostic {
      margin-top: 0.5rem;
      padding: 0.5rem;
      border: 1px solid var(--diag-border);
      border-radius: 4px;
      background: var(--diag-bg);
      font-size: 0.7rem;
      color: var(--error-text);
      display: none;
    }
    .diagnostic.visible { display: block; }

    .outage-block {
      margin-top: 1.5rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--card-bg-alt);
      padding: 1rem;
      display: none;
    }
    .outage-block.visible { display: block; }
    .outage-block summary {
      cursor: pointer;
      font-size: 0.75rem;
      color: var(--text-muted);
      user-select: none;
    }
    .outage-block pre {
      margin-top: 0.75rem;
      font-size: 0.72rem;
      color: var(--text-muted);
      overflow: auto;
    }

    .raw-block {
      margin-top: 1.5rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--card-bg-alt);
      padding: 1rem;
    }
    .raw-block summary {
      cursor: pointer;
      font-size: 0.75rem;
      color: var(--text-muted);
      user-select: none;
    }
    .raw-block pre {
      margin-top: 0.75rem;
      font-size: 0.72rem;
      color: var(--text-muted);
      overflow: auto;
      max-height: 300px;
    }

    .dash-header { margin-bottom: 2.5rem; text-align: center; }
    .dash-header h1 { font-size: 2rem; font-weight: 700; letter-spacing: -0.02em; color: var(--text); }
    .dash-header p  { margin-top: 0.5rem; color: var(--text-muted); font-size: 0.875rem; }

    .refresh-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      margin-top: 1rem;
      padding: 0.4rem 0.9rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: transparent;
      color: var(--text-muted);
      font-family: inherit;
      font-size: 0.75rem;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
    }
    .refresh-btn:hover { border-color: #334155; color: #94a3b8; }
  </style>

  <div class="dash-header">
    <h1>FullStackHex</h1>
    <p>Rust · Python sidecar · Astro · PostgreSQL · Redis · RustFS</p>
  </div>

      <div class="grid">
        <div class="card" id="card-rust">
          <div class="card-label">Rust API</div>
          <div class="status-row">
            <div class="dot loading" id="dot-rust"></div>
            <span class="status-text" id="text-rust">checking…</span>
          </div>
          <div class="detail" id="detail-rust"></div>
          <div class="diagnostic" id="diag-rust"></div>
        </div>

        <div class="card" id="card-db">
          <div class="card-label">PostgreSQL</div>
          <div class="status-row">
            <div class="dot loading" id="dot-db"></div>
            <span class="status-text" id="text-db">checking…</span>
          </div>
          <div class="detail" id="detail-db"></div>
          <div class="diagnostic" id="diag-db"></div>
        </div>

        <div class="card" id="card-redis">
          <div class="card-label">Redis</div>
          <div class="status-row">
            <div class="dot loading" id="dot-redis"></div>
            <span class="status-text" id="text-redis">checking…</span>
          </div>
          <div class="detail" id="detail-redis"></div>
          <div class="diagnostic" id="diag-redis"></div>
        </div>

        <div class="card" id="card-storage">
          <div class="card-label">RustFS Storage</div>
          <div class="status-row">
            <div class="dot loading" id="dot-storage"></div>
            <span class="status-text" id="text-storage">checking…</span>
          </div>
          <div class="detail" id="detail-storage"></div>
          <div class="diagnostic" id="diag-storage"></div>
        </div>

        <div class="card" id="card-python">
          <div class="card-label">Python sidecar</div>
          <div class="status-row">
            <div class="dot loading" id="dot-python"></div>
            <span class="status-text" id="text-python">checking…</span>
          </div>
          <div class="detail" id="detail-python"></div>
          <div class="diagnostic" id="diag-python"></div>
        </div>

        <div class="card" id="card-auth">
          <div class="card-label">Auth</div>
          <div class="status-row">
            <div class="dot loading" id="dot-auth"></div>
            <span class="status-text" id="text-auth">checking…</span>
          </div>
          <div class="detail" id="detail-auth"></div>
          <div class="diagnostic" id="diag-auth"></div>
        </div>
      </div>

      <div class="outage-block" id="outage-block">
        <details>
          <summary>All services down — recovery steps</summary>
          <pre>make down-dev && make dev
docker compose -f compose/dev.yml logs
make status</pre>
        </details>
      </div>

      <div class="raw-block">
        <details>
          <summary>raw /health response</summary>
          <pre id="raw-json">fetching…</pre>
        </details>
      </div>

      <div style="text-align:center">
        <button class="refresh-btn" id="refresh-btn">↺ refresh</button>
      </div>

    <script>
      import { SERVICE_IDS, isFullOutage as checkFullOutage } from "../lib/health";
      import { connectLiveStream } from "../lib/live";

      let wsFallbackTimer: ReturnType<typeof setTimeout> | null = null;
      let wsDisconnected = true;

      function setStatus(id: string, status: string, label: string) {
        const dot  = document.getElementById("dot-"  + id);
        const text = document.getElementById("text-" + id);
        if (dot)  dot.className    = "dot " + (status || "loading");
        if (text) text.textContent = label || status || "…";
      }

      function setDetail(id: string, text: string) {
        const el = document.getElementById("detail-" + id);
        if (el) el.textContent = text || "";
      }

      function setDiagnostic(id: string, text: string) {
        const el = document.getElementById("diag-" + id);
        if (!el) return;
        if (text) {
          el.textContent = text;
          el.classList.add("visible");
        } else {
          el.textContent = "";
          el.classList.remove("visible");
        }
      }

      function showOutage(visible: boolean) {
        const el = document.getElementById("outage-block");
        if (el) el.classList.toggle("visible", visible);
      }

      const isFullOutage = checkFullOutage;

      let retryTimer: ReturnType<typeof setTimeout> | null = null;
      let retryDelay = 1000;

      function startRetry() {
        cancelRetry();
        if (retryDelay > 30000) retryDelay = 30000;
        retryTimer = setTimeout(() => {
          fetchHealth();
          retryDelay = Math.min(retryDelay * 2, 30000);
          startRetry();
        }, retryDelay);
      }

      function cancelRetry() {
        if (retryTimer !== null) {
          clearTimeout(retryTimer);
          retryTimer = null;
        }
      }

      function resetRetry() {
        cancelRetry();
        retryDelay = 1000;
      }

      async function fetchHealth() {
        const rawJson = document.getElementById("raw-json");
        if (rawJson) rawJson.textContent = "fetching…";

        try {
          const res  = await fetch("/api/health");
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          const data = await res.json();

          if (rawJson) rawJson.textContent = JSON.stringify(data, null, 2);

          for (const svc of SERVICE_IDS) {
            const entry = data[svc] as Record<string, unknown> | undefined;
            if (!entry) {
              setStatus(svc, "error", "unknown");
              continue;
            }
            const status = entry.status as string;

            // Rust
            if (svc === "rust") {
              setStatus("rust", status === "ok" ? "ok" : "error", status || "unknown");
              if (status !== "ok") setDiagnostic("rust", (entry.fix as string) || (entry.error as string) || "");

            // DB
            } else if (svc === "db") {
              setStatus("db",
                status === "ok" ? "ok" : status === "error" ? "error" : "degraded",
                entry.error ? "error: " + entry.error : status || "unknown");
              if (status !== "ok") setDiagnostic("db", (entry.fix as string) || (entry.error as string) || "");

            // Redis
            } else if (svc === "redis") {
              setStatus("redis",
                status === "ok" ? "ok" : status === "error" ? "error" : "degraded",
                status || "unknown");
              if (status !== "ok") setDiagnostic("redis", (entry.fix as string) || (entry.error as string) || "");

            // Storage
            } else if (svc === "storage") {
              setStatus("storage",
                status === "ok" ? "ok" : status === "error" ? "error" : "degraded",
                entry.error ? "error: " + entry.error : status || "unknown");
              if (status !== "ok") setDiagnostic("storage", (entry.fix as string) || (entry.error as string) || "");

            // Python
            } else if (svc === "python") {
              const pyLabel =
                status === "ok" ? "ok" :
                status === "unavailable" ? "not running" :
                status === "error" ? "error" : "unknown";
              setStatus("python",
                status === "ok" ? "ok" : status === "unavailable" ? "degraded" : "error",
                pyLabel);
              if (status !== "ok") setDiagnostic("python", (entry.fix as string) || (entry.error as string) || "");
              if (entry.detail) {
                setDetail("python", JSON.stringify(entry.detail, null, 2));
              } else if (entry.error) {
                setDetail("python", entry.error as string);
              } else {
                setDetail("python", "");
              }

            // Auth
            } else if (svc === "auth") {
              if (status === "ok") {
                setStatus("auth", "ok", "enabled");
                setDetail("auth", "");
              } else {
                setStatus("auth", "degraded", "disabled");
                setDetail("auth", (entry.fix as string) || "JWT_SECRET not set — auth disabled");
                setDiagnostic("auth", (entry.fix as string) || "");
              }
            }
          }

          if (isFullOutage(data)) {
            showOutage(true);
            startRetry();
          }

        } catch (err) {
          for (const svc of SERVICE_IDS) {
            setStatus(svc, "error", svc === "rust" ? "unreachable" : "—");
            setDiagnostic(svc, "");
          }
          showOutage(true);
          const msg = err instanceof Error ? err.message : String(err);
          if (rawJson) rawJson.textContent =
            "Error: could not reach /api/health — backend may be down\n\n" + msg +
            "\n\nTry: make down-dev && make dev";
          startRetry();
        }
      }

      // ── WebSocket live updates with polling fallback ──
      function applyHealthUpdate(event: import("../lib/live").LiveEvent) {
        if (event.type !== "health_update") return;
        const { service, status, detail } = event.data;
        if (status === "ok") {
          setStatus(service, "ok", "ok");
          setDetail(service, "");
          setDiagnostic(service, "");
        } else {
          setStatus(service, "error", status);
          if (detail) setDetail(service, detail);
        }
      }

      function initLiveStream() {
        const live = connectLiveStream();

        live.onEvent((event: import("../lib/live").LiveEvent) => {
          wsDisconnected = false;
          if (event.type === "connection_status") {
            if (event.data.status === "connected") {
              wsDisconnected = false;
              cancelRetry();
              if (wsFallbackTimer !== null) {
                clearTimeout(wsFallbackTimer);
                wsFallbackTimer = null;
              }
            } else if (event.data.status === "offline") {
              wsDisconnected = true;
              if (wsFallbackTimer === null) {
                wsFallbackTimer = setTimeout(() => {
                  wsFallbackTimer = null;
                  if (wsDisconnected) {
                    console.log("[dashboard] WS unavailable — falling back to polling");
                    fetchHealth();
                  }
                }, 3000);
              }
            }
            return;
          }
          applyHealthUpdate(event);
        });

        window.addEventListener("beforeunload", () => live.close());
      }

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          cancelRetry();
        } else {
          resetRetry();
          fetchHealth();
        }
      });

      document.getElementById("refresh-btn")?.addEventListener("click", () => {
        resetRetry();
        fetchHealth();
      });

      // Try WS first, fall back to polling if no connect within 2s
      initLiveStream();
      wsFallbackTimer = setTimeout(() => {
        wsFallbackTimer = null;
        if (wsDisconnected) {
          console.log("[dashboard] WS connect timeout — using polling");
          fetchHealth();
        }
      }, 2000);
    </script>
</Layout>

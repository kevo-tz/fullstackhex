---
import Layout from "../components/Layout.astro";
export const prerender = false;
---

<Layout title="Reset password — FullStackHex">
  <div class="max-w-sm mx-auto" style="margin-top:3rem">
    <header style="margin-bottom:2rem;text-align:center">
      <h1 style="font-size:1.5rem;font-weight:700;color:#f8fafc">Reset password</h1>
    </header>

    <div class="card" style="max-width:400px;margin:0 auto">
      <div class="error-msg" id="auth-error"></div>
      <div class="success-msg hidden" id="auth-success"></div>

      <!-- Missing token state -->
      <div id="missing-token" class="hidden">
        <p style="color:#fca5a5;font-size:0.85rem;text-align:center">Invalid or missing reset token.</p>
        <div style="text-align:center;margin-top:1rem">
          <a href="/forgot-password" style="color:var(--accent,#22c55e);font-size:0.85rem">Request a new reset link</a>
        </div>
      </div>

      <form id="reset-form">
        <input type="hidden" id="token-input" />
        <div class="form-group">
          <label for="password">New password</label>
          <input id="password" name="password" type="password" placeholder="Min 8 characters" required minlength="8" autocomplete="new-password" />
        </div>
        <div class="form-group">
          <label for="confirm-password">Confirm password</label>
          <input id="confirm-password" type="password" placeholder="Repeat password" required minlength="8" autocomplete="new-password" />
        </div>
        <button type="submit" class="btn" id="submit-btn">Reset password</button>
      </form>
    </div>

    <div class="form-footer">
      <a href="/login">Back to sign in</a>
    </div>
  </div>
</Layout>

<script>
  const token = new URLSearchParams(window.location.search).get("token");
  const tokenInput = document.getElementById("token-input") as HTMLInputElement;
  const form = document.getElementById("reset-form") as HTMLFormElement;
  const missingToken = document.getElementById("missing-token") as HTMLDivElement;
  const error = document.getElementById("auth-error") as HTMLDivElement;
  const success = document.getElementById("auth-success") as HTMLDivElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const passwordInput = document.getElementById("password") as HTMLInputElement;
  const confirmInput = document.getElementById("confirm-password") as HTMLInputElement;

  if (!token) {
    form.classList.add("hidden");
    missingToken.classList.remove("hidden");
  } else {
    tokenInput.value = token;
  }

  function showError(msg: string) {
    error.textContent = msg;
    error.classList.add("visible");
  }
  function hideError() {
    error.textContent = "";
    error.classList.remove("visible");
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    hideError();
    success.classList.add("hidden");
    btn.disabled = true;
    btn.textContent = "…";

    const password = passwordInput.value;
    const confirm = confirmInput.value;

    if (password !== confirm) {
      showError("Passwords do not match");
      btn.disabled = false;
      btn.textContent = "Reset password";
      return;
    }

    if (password.length < 8) {
      showError("Password must be at least 8 characters");
      btn.disabled = false;
      btn.textContent = "Reset password";
      return;
    }

    try {
      const res = await fetch("/api/auth/reset-password", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ token, password }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        const msg = typeof data.error === "string" ? data.error : `Request failed (${res.status})`;
        throw new Error(msg);
      }

      success.textContent = "Password updated successfully! Redirecting to sign in…";
      success.classList.remove("hidden");
      form.classList.add("hidden");

      setTimeout(() => { window.location.href = "/login"; }, 2000);
    } catch (err) {
      showError(err instanceof Error ? err.message : "Something went wrong");
      btn.disabled = false;
      btn.textContent = "Reset password";
    }
  });
</script>

<style>
  .card {
    padding: 2rem;
    border-radius: 12px;
    background: var(--card-bg, #111827);
    border: 1px solid var(--border, #1e293b);
  }
  .form-group { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1rem; }
  .form-group label { font-size: 0.8rem; color: var(--text-muted, #94a3b8); }
  .form-group input {
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--border, #1e293b);
    border-radius: 6px;
    background: var(--card-bg, #111827);
    color: var(--text, #e2e8f0);
    font-size: 0.9rem;
    font-family: inherit;
    width: 100%;
    box-sizing: border-box;
  }
  .form-group input:focus { outline: none; border-color: var(--accent, #22c55e); }
  .btn {
    width: 100%;
    padding: 0.65rem;
    border-radius: 6px;
    background: var(--accent, #22c55e);
    color: var(--btn-text, #0d0d0d);
    border: none;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
  }
  .btn:hover { opacity: 0.9; }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .error-msg {
    padding: 0.65rem;
    border-radius: 6px;
    background: #450a0a;
    border: 1px solid #7f1d1d;
    color: #fca5a5;
    font-size: 0.82rem;
    margin-bottom: 1rem;
    display: none;
  }
  .error-msg.visible { display: block; }
  .success-msg {
    padding: 0.65rem;
    border-radius: 6px;
    background: #064e3b;
    border: 1px solid #065f46;
    color: #6ee7b7;
    font-size: 0.82rem;
    margin-bottom: 1rem;
  }
  .form-footer { text-align: center; margin-top: 1.5rem; }
  .form-footer a { color: var(--accent, #22c55e); font-size: 0.85rem; text-decoration: none; }
  .form-footer a:hover { text-decoration: underline; }
  .hidden { display: none; }
</style>
